{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://yazelin.github.io/workshop/schemas/artifact.schema.json",
  "title": "Forest Workshop Artifact",
  "description": "森之召喚師工坊魔道具條目規格",
  "type": "object",
  "required": ["id", "icon", "nameZh", "nameEn", "school", "schoolEn", "repo", "lore", "effect", "actions"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,39}$",
      "description": "全站唯一識別，小寫 + 連字號"
    },
    "icon": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4,
      "description": "一個 emoji 字元"
    },
    "nameZh": {
      "type": "string",
      "minLength": 2,
      "maxLength": 12,
      "description": "中文魔道具名，奇幻風（推薦 4-8 字）"
    },
    "nameEn": {
      "type": "string",
      "minLength": 2,
      "maxLength": 40,
      "pattern": "^[A-Z]",
      "description": "英文名，首字母大寫"
    },
    "school": {
      "type": "string",
      "enum": ["召喚系", "幻術系", "創造系", "煉金系", "次元系", "通靈系", "聲術系"]
    },
    "schoolEn": {
      "type": "string",
      "enum": ["Summoning", "Illusion", "Creation", "Transmutation", "Dimensional", "Binding", "Incantation"]
    },
    "repo": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+/[a-zA-Z0-9._-]+$",
      "description": "GitHub 完整 repo 名，格式 owner/name"
    },
    "lore": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "奇幻敘事典故，1-3 句，可含 <br>"
    },
    "effect": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "技術效能描述，1-2 句"
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["label", "url"],
        "additionalProperties": false,
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20
          },
          "url": {
            "type": "string",
            "format": "uri",
            "pattern": "^https?://"
          },
          "primary": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
